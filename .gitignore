# RETROX repo ignore. The dev tree only contains source — runtime
# folders (data, roms, emulators) and the compiled binary are produced
# locally and shipped via the portable zip, not via git.

# Compiled binary
/retrox

# Runtime / portable bundle dirs
/data/
/roms/
/emulators/

# Embedded SPA build output (regenerated by `make web`)
/web/
/retrox-web/out/
/retrox-web/node_modules/
/retrox-web/dist/

# Packaging artifacts
/dist/
*.zip

# Editor / OS cruft
.DS_Store
*.swp
.vscode/
.idea/

# Claude Code local overrides (host-specific permission grants etc.)
.claude/settings.local.json
